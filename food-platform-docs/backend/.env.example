# Backend Environment Variables

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/society_food
DB_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
WORKERS=4

# Security
SECRET_KEY=change-me-in-production-with-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP Configuration
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_LENGTH=6

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SENDER_EMAIL=noreply@societyfood.com
SENDER_NAME="Society Food Platform"

# Twilio/WhatsApp Configuration (Optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Redis Configuration (Optional)
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=development

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Sentry (Error Tracking - Optional)
SENTRY_DSN=

# Rate Limiting
RATE_LIMIT_CALLS=100
RATE_LIMIT_PERIOD=60

# Feature Flags
ENABLE_OTP_EMAIL=true
ENABLE_OTP_WHATSAPP=false
ENABLE_WEBSOCKET=false
